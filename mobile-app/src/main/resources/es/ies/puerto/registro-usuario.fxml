<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="es.ies.puerto.controllers.RegistroUsuarioController">
    <Label text="Registrar Usuario" />
    <TextField fx:id="txtNombre" promptText="Nombre" />
    <TextField fx:id="txtDni" promptText="DNI" />
    <TextField fx:id="txtEmail" promptText="Email" />
    <TextField fx:id="txtTelefono" promptText="Teléfono" />
    <Button fx:id="btnRegistrar" onAction="#registrarUsuario" text="Registrar" />
</VBox>